# Data Engineering Project — Standard .gitignore Template
# This excludes data files, secrets, models, and build artifacts

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
