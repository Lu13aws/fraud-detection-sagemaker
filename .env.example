# SageMaker (Optional - Required if using SageMaker training)
SAGEMAKER_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/SageMakerRole
SAGEMAKER_EXECUTION_ROLE=arn:aws:iam::ACCOUNT_ID:role/SageMakerRole
